#   gpt-5.4-low                        GPT-5.4 1M Low
#   gpt-5.4-medium                     GPT-5.4 1M
#   gpt-5.4-medium-fast                GPT-5.4 Fast
#   gpt-5.4-mini-high                  GPT-5.4 Mini High
#   gpt-5.4-mini-low                   GPT-5.4 Mini Low
#   gpt-5.4-mini-medium                GPT-5.4 Mini
#   gpt-5.4-mini-none                  GPT-5.4 Mini None
#   gpt-5.4-mini-xhigh                 GPT-5.4 Mini Extra High
#   gpt-5.4-nano-high                  GPT-5.4 Nano High
#   gpt-5.4-nano-low                   GPT-5.4 Nano Low
#   gpt-5.4-nano-medium                GPT-5.4 Nano
#   gpt-5.4-nano-none                  GPT-5.4 Nano None
#   gpt-5.4-nano-xhigh                 GPT-5.4 Nano Extra High
#   gpt-5.4-xhigh                      GPT-5.4 1M Extra High
#   gpt-5.4-xhigh-fast                 GPT-5.4 Extra High Fast
#   grok-4-20                          Grok 4.20
#   grok-4-20-thinking                 Grok 4.20 Thinking
#   kimi-k2.5                          Kimi K2.5
# CURSOR_AGENT_MODEL=auto
# CURSOR_AGENT_MODEL=composer-2

# Cursor CLI session continuity (agent create-chat + --resume):
#   off     — cold CLI every invocation
#   bigboss — only BigBoss-shaped calls share one chat per pipeline (default when unset, unless BIGBOSS_PERSIST_CLI=0)
#   all     — each agentType (ux-designer, coding, …) gets its own lazy chat per pipeline; release stays cold
# CURSOR_AGENT_SESSIONS=all
#
# Legacy: BIGBOSS_PERSIST_CLI=0 disables sessions when CURSOR_AGENT_SESSIONS is not set.
# BIGBOSS_PERSIST_CLI=0

# OpenAI model for BigBoss planning and summarisation (default: gpt-4o-mini)
# Set to gpt-4o for better planning accuracy at higher cost.
# BIGBOSS_MODEL=gpt-4o-mini

# OpenAI model for design document merge (default: same as BIGBOSS_MODEL)
# MERGE_MODEL=gpt-4o-mini

# --- Spec-kit Tier 1 (constitution.md + TASKS.md) -------------------------------
# When set to 1, the orchestrator drafts an initial .specify/memory/constitution.md
# from the user's task prompt if no constitution file exists yet. The constitution
# is then loaded into every agent's prompt as project-wide governance. Disabled by
# default to avoid surprising users by writing files into existing repos.
#
# Resolution order for the loader (first match wins):
#   1. <workDir>/.specify/memory/constitution.md  (spec-kit convention)
#   2. <workDir>/CONSTITUTION.md                  (root-level convention)
# CONSTITUTION_BOOTSTRAP=1
#
# TASKS.md is generated automatically after design merge (no env required); it is
# read by coding/lua-coding agents as the executable task list. When OPENAI_API_KEY
# is set, BigBoss extracts concrete tasks with file paths and REQUIREMENTS ids;
# otherwise a stage-derived skeleton is written.

# --- Spec-kit Tier 2 (v2 artefact schema) ---------------------------------------
# DEFAULT: v2 (since v2.7). The orchestrator writes spec.md, plan.md (and
# optionally research.md / data-model.md / contracts/) plus CHECKLISTS.md after
# the design merge, prepends spec.md + plan.md previews to coding-agent prompts,
# and inserts the discrete clarify / analyze / checklist Overseer sub-stages.
#
# Set to "v1" for one-release opt-out to the legacy single-DESIGN.md flow with
# inline post-design / post-coding Overseer reviews and the LOVE_SMOKE_CHECKLIST
# env path. Anything other than "v1" (unset, empty, "v2", unknown) → v2.
# ARTEFACT_SCHEMA=v1

# --- Spec-kit Tier 2 PR3 (checklist stage) --------------------------------------
# When ARTEFACT_SCHEMA=v2, the orchestrator inserts a `checklist` stage between
# `analyze` and `validation`. The stage runs a read-only OpenAI pass over
# CHECKLISTS.md, ticks items it can confirm, and (on `incomplete`) hands off to
# a SINGLE focused coding fix-up before validation runs.
#
# Default behaviour is advisory-only: even on `incomplete`, the pipeline
# continues to validation/release. Setting CHECKLIST_BLOCKING=1 fails the
# pipeline when the checklist is still `incomplete` after the fix-up budget
# (MAX_CHECKLIST_FIX_ITERATIONS=1) is exhausted.
# CHECKLIST_BLOCKING=1
#
# DEPRECATED: LOVE_SMOKE_CHECKLIST=1 still works for v1 pipelines but emits a
# warning once per task when v2 is active. The v2 `checklist` stage is
# stack-agnostic and inherits the existing LÖVE smoke bullets automatically.
# LOVE_SMOKE_CHECKLIST=1
