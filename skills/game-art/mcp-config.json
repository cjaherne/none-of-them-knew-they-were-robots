{
  "mcpServers": {
    "filesystem": {
      "command": "mcp-server-filesystem",
      "args": ["/workspace"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "openai-sprite-mcp": {
      "command": "node",
      "args": ["__OPENAI_SPRITE_MCP_ENTRY__", "__PIPELINE_WORKSPACE__"]
    }
  }
}
